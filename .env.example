# Casca v2.1 — Environment Variables
# Copy to .env and fill in your values

# ── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# ── Admin portal protection ────────────────────────────
# Used as fallback auth for CLI / scripts.
# Admin Portal (casca-admin.html) uses Supabase JWT as primary auth.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=replace-with-a-strong-random-string

# ── Server ─────────────────────────────────────────────
PORT=3001

# ── CORS ───────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Include ALL your frontend domains (landing, admin, dashboard).
# Use * for development only.
CORS_ORIGIN=https://cascaio.com,https://www.cascaio.com,https://admin.cascaio.com

# ── LLM Proxy ──────────────────────────────────────────
# Hard timeout per LLM call (milliseconds)
LLM_TIMEOUT_MS=30000

# ── Tenant Cache Promotion ─────────────────────────────
# How many times a prompt must repeat (within window) before
# its response is promoted into tenant_cache_pool
CACHE_PROMOTE_THRESHOLD=3

# Sliding window for frequency counting (hours)
CACHE_PROMOTE_WINDOW_H=24

# Cache entry lifetime in days (0 = never expire)
CACHE_TTL_DAYS=7

# ── Stripe (Phase 2) ──────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...

# ── Path B: Training Pipeline ─────────────────────────
# Set to 'true' to enable async training pipeline (PII mask → LLM Judge → training_samples)
PATH_B_ENABLED=false

# LLM model used to judge prompt complexity (ground truth)
PATH_B_JUDGE_MODEL=gpt-4o-mini

# Fraction of requests to send to LLM Judge (1.0 = all, 0.5 = 50%)
PATH_B_SAMPLE_RATE=1.0

# Dynamic confidence threshold: below this → invoke L2 MiniLM
PATH_B_CONFIDENCE_THRESHOLD=80

# MiniLM service URL (Railway internal networking)
MINILM_SERVICE_URL=http://casca-minilm.railway.internal:8000
