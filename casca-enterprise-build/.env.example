# ══════════════════════════════════════════════════════════════
# Casca Enterprise — On-Premise Configuration
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# License (required — provided by Casca admin)
CASCA_LICENSE_KEY=ent_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Casca Cloud URL (for license validation, usage reporting, updates)
# Set to empty for air-gapped deployments with offline license
CASCA_CLOUD_URL=https://api.cascaio.com

# Engine
ENGINE_PORT=3001
CORS_ORIGIN=*
LLM_TIMEOUT_MS=30000
ADMIN_SECRET=change_this_to_a_strong_secret

# Database
DB_PASSWORD=cascapass

# Path B (set to true to enable continuous learning)
PATH_B_ENABLED=false

# Agent intervals (seconds)
HEARTBEAT_INTERVAL=3600
USAGE_REPORT_INTERVAL=3600
LICENSE_CHECK_INTERVAL=86400
UPDATE_CHECK_INTERVAL=21600
GRACE_PERIOD_DAYS=7
AUTO_UPDATE=false
