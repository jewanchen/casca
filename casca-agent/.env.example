# Casca Enterprise Agent — Configuration

# License key (provided by Casca admin)
CASCA_LICENSE_KEY=ent_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Casca Cloud URL (for phone-home, usage, updates)
CASCA_CLOUD_URL=https://api.cascaio.com

# Local Casca Engine URL (the compiled binary running locally)
CASCA_ENGINE_URL=http://localhost:3001

# Local database for usage tracking
# Agent reads api_logs from this DB to compute usage reports
DATABASE_URL=postgresql://casca:password@localhost:5432/casca

# Intervals (seconds)
HEARTBEAT_INTERVAL=3600        # 1 hour
USAGE_REPORT_INTERVAL=3600     # 1 hour
LICENSE_CHECK_INTERVAL=86400   # 24 hours
UPDATE_CHECK_INTERVAL=21600    # 6 hours

# Grace period (days) — how long engine runs without license validation
GRACE_PERIOD_DAYS=7

# Auto-update (set to false for manual updates)
AUTO_UPDATE=false

# Logging
LOG_LEVEL=info
