# Casca MiniLM Service — Environment Variables

# Supabase (for fetching training data and writing model versions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# Model config
MODEL_NAME=microsoft/MiniLM-L6-H384-uncased
NUM_LABELS=3
CHECKPOINT_DIR=./model/checkpoints
ACTIVE_CHECKPOINT=

# Training config
TRAIN_BATCH_SIZE=32
EVAL_BATCH_SIZE=64
LEARNING_RATE=2e-5
NUM_EPOCHS=5
WARMUP_RATIO=0.1
AUTO_TRAIN_THRESHOLD=500

# Server
PORT=8000
